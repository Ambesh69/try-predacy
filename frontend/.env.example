# ── Privy ─────────────────────────────────────────────────────────
# Get from https://dashboard.privy.io
# Configure in dashboard: wallet-only login, Solana chain, no email/social
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# ── Relayer ───────────────────────────────────────────────────────
NEXT_PUBLIC_RELAYER_URL=http://localhost:3001

# ── Solana Program ────────────────────────────────────────────────
NEXT_PUBLIC_PROGRAM_ID=Bb3zRkLip445BQ1S44PC115aws8CCyag4KFkch9ZcKjp

# ── Solana RPC ────────────────────────────────────────────────────
# IMPORTANT FOR PRIVACY: the RPC provider sees every query your client
# makes — including which addresses you look up. For production, use a
# no-log privacy RPC. See docs/ARCHITECTURE.md §2 for why this matters.
#
# RECOMMENDED: RPC Fast (hackathon sponsor, trading-optimized, SWQoS, gRPC
# streaming). Sign up at https://solana.rpcfast.com/login — ask for the
# Hackathon plan for devnet support. Usage:
#   NEXT_PUBLIC_SOLANA_RPC_URL=https://solana-rpc.rpcfast.com/
#   NEXT_PUBLIC_SOLANA_RPC_TOKEN=YOUR_API_KEY   (passed as X-Token header)
#
# Alternatives:
#   Helius (no-log commitment, free tier, key required):
#     https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#     https://devnet.helius-rpc.com/?api-key=YOUR_KEY
#
#   Triton One (public, no key, Tor-reachable):
#     https://solana-rpc.publicnode.com
#
#   Ankr (public, no key):
#     https://rpc.ankr.com/solana
#     https://rpc.ankr.com/solana_devnet
#
# Devnet default below is Solana's public endpoint — NOT privacy-preserving.
# Only acceptable for dev/testing; replace before mainnet.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_TOKEN=

# ── Umbra Privacy ────────────────────────────────────────────────
# Umbra has live Solana devnet contracts at
# `DSuKkyqGVGgo4QtPABfxKJKygUDACbUhirnuv63mEpAJ`.
# The default in `lib/umbra.ts` picks the right devnet indexer when
# NEXT_PUBLIC_UMBRA_NETWORK=devnet — override these only if you want
# mainnet (indexer.umbraprivacy.com) or a custom instance.
NEXT_PUBLIC_UMBRA_NETWORK=devnet
# NEXT_PUBLIC_UMBRA_INDEXER=https://utxo-indexer.api-devnet.umbraprivacy.com
