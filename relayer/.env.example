# ── Solana Network ────────────────────────────────────────────────
# Fallback RPC if RPC_FAST_API_KEY is not set.
# Local dev: http://127.0.0.1:8899
# Devnet:    https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── RPC Fast ──────────────────────────────────────────────────────
# Sign up at https://solana.rpcfast.com/login — Hackathon plan gives
# devnet access for both HTTP RPC and Yellowstone gRPC (as separate apps
# on the dashboard, each with its own API key).
#
# When RPC_FAST_API_KEY is set, the relayer:
#   1. Uses the HTTP endpoint as primary RPC (X-Token auth)
#   2. Opens WebSocket onLogs subscription for live program events
#   3. Pushes events to frontend via SSE GET /events
#   4. Uses SWQoS for priority transaction routing
#
# When RPC_FAST_GRPC_API_KEY is also set AND RPC_FAST_GRPC_ENABLED=true,
# the relayer additionally opens a Yellowstone gRPC stream (sub-100ms
# latency, richer filters — replaces WebSocket as primary event source).
#
# If both are unset, the relayer falls back to SOLANA_RPC_URL + polling.

# HTTP RPC app (devnet example — override for mainnet)
RPC_FAST_API_KEY=
RPC_FAST_HTTP_URL=https://sol-devnet-rpc.rpcfast.com
RPC_FAST_WSS_URL=wss://sol-devnet-rpc.rpcfast.com

# Yellowstone gRPC app (separate dashboard app, separate key)
RPC_FAST_GRPC_ENABLED=false
RPC_FAST_GRPC_API_KEY=
RPC_FAST_YELLOWSTONE_URL=https://sol-devnet-yellowstone-grpc.rpcfast.com:443

# ── Relayer Wallet ────────────────────────────────────────────────
# Either set RELAYER_KEYPAIR_JSON (raw JSON array of secret key bytes)
# or RELAYER_KEYPAIR_PATH (path to Solana keypair file).
# Defaults to ~/.config/solana/id.json
RELAYER_KEYPAIR_PATH=

# ── Solana Program ────────────────────────────────────────────────
PROGRAM_ID=Bb3zRkLip445BQ1S44PC115aws8CCyag4KFkch9ZcKjp

# ── ZK Prover ─────────────────────────────────────────────────────
# true  → relayer runs snarkjs.groth16.fullProve on the batch + claim
#         circuits for every settle + claim (~500ms-1s per proof)
# false → mock proofs (all-zero bytes, for local testing when circuits
#         haven't been built or the user wants faster iteration)
#
# On-chain verification of these proofs is not yet live — the Anchor
# program accepts the proof bytes but doesn't run Groth16Verifier.
# See docs/ARCHITECTURE.md §13 for status.
USE_REAL_ZK=true

# ── Ika dWallet (Pre-Alpha, devnet) ───────────────────────────────
# Solana-native signing for any chain (Ed25519 / ECDSA / Schnorr) via the
# Ika dWallet program + gRPC signing network. Pre-Alpha uses a single
# mock signer; real 2PC-MPC ships with Ika Alpha 1.
#
# When IKA_ENABLED=true, the relayer exposes:
#   POST /ika/dwallet  — ensure a dWallet exists for a user (DKG)
#   POST /ika/presign  — allocate a presign
#
# See https://solana-pre-alpha.ika.xyz for docs.
IKA_ENABLED=false
IKA_PROGRAM_ID=87W54kGYFQ1rgWqMeu4XTPHWXWmXSQCcjm8vCTfiq1oY
IKA_GRPC_URL=pre-alpha-dev-1.ika.ika-network.net:443

# ── Server ────────────────────────────────────────────────────────
PORT=3001
