# ── Solana Network ────────────────────────────────────────────────
# Fallback RPC if RPC_FAST_API_KEY is not set.
# Local dev: http://127.0.0.1:8899
# Devnet:    https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── RPC Fast (recommended for production) ─────────────────────────
# Get an API key from https://solana.rpcfast.com/login
# Ask for the Hackathon plan for devnet access.
#
# When RPC_FAST_API_KEY is set, the relayer:
#   1. Uses https://solana-rpc.rpcfast.com/ as primary RPC (X-Token auth)
#   2. Opens a Yellowstone gRPC subscription for live program events
#   3. Pushes on-chain events (commit_order, settle_batch, claim) to frontend
#      via SSE at GET /events — replaces client polling
#   4. Uses SWQoS for priority transaction routing (claims land faster)
#
# If unset, the relayer falls back to SOLANA_RPC_URL and polling. All features
# still work, just slower.
RPC_FAST_API_KEY=
RPC_FAST_HTTP_URL=https://solana-rpc.rpcfast.com/
RPC_FAST_YELLOWSTONE_URL=https://solana-yellowstone-grpc.rpcfast.com:443

# ── Relayer Wallet ────────────────────────────────────────────────
# Either set RELAYER_KEYPAIR_JSON (raw JSON array of secret key bytes)
# or RELAYER_KEYPAIR_PATH (path to Solana keypair file).
# Defaults to ~/.config/solana/id.json
RELAYER_KEYPAIR_PATH=

# ── Solana Program ────────────────────────────────────────────────
PROGRAM_ID=Bb3zRkLip445BQ1S44PC115aws8CCyag4KFkch9ZcKjp

# ── ZK Prover ─────────────────────────────────────────────────────
# true  → generate real Groth16 proofs (slow, needs circuits built)
# false → use mock proofs (fast dev / hackathon demo)
USE_REAL_ZK=false

# ── Server ────────────────────────────────────────────────────────
PORT=3001
